# ── Database ──────────────────────────────────────────────────────────────────
MANDREL_DATABASE_URL=postgresql+asyncpg://mandrel:mandrel@localhost:5432/mandrel

# ── Artifact storage ──────────────────────────────────────────────────────────
# Local workspace root; each project gets its own git-versioned subdirectory.
MANDREL_WORKSPACE_DIR=./workspace

# MinIO (optional S3-compatible artifact mirror)
MANDREL_MINIO_ENDPOINT=localhost:9000
MANDREL_MINIO_ACCESS_KEY=mandrel
MANDREL_MINIO_SECRET_KEY=mandrel123
MANDREL_MINIO_BUCKET=mandrel-artifacts

# ── LLM provider ─────────────────────────────────────────────────────────────
# Default: Ollama local inference (OpenAI-compatible /v1 endpoint).
# Swap MANDREL_LLM_BASE_URL for any OpenAI-compatible service (vLLM, OpenAI, etc.)
MANDREL_LLM_BASE_URL=http://localhost:11434/v1
MANDREL_LLM_MODEL=gemma4:26b
# Leave blank for Ollama (no key required). Set for paid APIs.
MANDREL_LLM_API_KEY=

# ── Distributor API keys (bring your own; responses cached locally) ────────────
MANDREL_DIGIKEY_CLIENT_ID=
MANDREL_DIGIKEY_CLIENT_SECRET=
MANDREL_MOUSER_API_KEY=
MANDREL_OCTOPART_API_KEY=
MANDREL_LCSC_API_KEY=

# ── Engine paths (only needed when not using Docker engine containers) ─────────
# These tools run out-of-process. Set paths if installed locally rather than
# using the --profile engines Docker containers.
MANDREL_KICAD_CLI_PATH=kicad-cli
MANDREL_FREEROUTING_JAR_PATH=freerouting.jar
MANDREL_FREECAD_CMD_PATH=freecadcmd
MANDREL_NGSPICE_PATH=ngspice
MANDREL_CALCULIX_PATH=ccx
